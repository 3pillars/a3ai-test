# OpenClaw Token Backend Environment Variables

# Server
PORT=3000
NODE_ENV=development

# Blockchain
OCT_TOKEN_ADDRESS=0x0000000000000000000000000000000000000000
STAKING_CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000
SERVICE_REGISTRY_ADDRESS=0x0000000000000000000000000000000000000000

# Blockchain RPC (Base)
BASE_RPC_URL=https://mainnet.base.org
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org

# Database (optional)
REDIS_URL=redis://localhost:6379
DATABASE_URL=postgresql://localhost:5432/oct

# AI Service (optional)
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# Security
JWT_SECRET=your-secret-key-here
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000
